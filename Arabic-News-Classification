    "# This converts strings into the float numbers the model requires\n",
    "X_numeric = tfidf_vec.transform(df['cleaned_text'])\n",
    "y_labels = df['label']\n",
    "\n",
    "# Now cross_val_score receives numbers, not strings\n",
    "cv_scores = cross_val_score(models[\"SVM\"], X_numeric, y_labels, cv=5)\n",
    "print(f\"Mean Cross-Validation Accuracy: {cv_scores.mean():.2%}\")\n",
    "print(f\"Stability (Std Dev): {cv_scores.std():.4f}\")\n",
    "print(\"-\" * 50)\n",
    "\n",
    "\n",
    "# --- 6.2: Error Analysis (Identifying Model Weaknesses) ---\n",
    "print(\"--- 2. Qualitative Error Analysis (Misclassified Samples) ---\")\n",
