    "from sklearn.model_selection import cross_val_score\n",
    "from sklearn.metrics import accuracy_score\n",
    "\n",
    "# --- 6.1: Cross-Validation (Testing Model Stability) ---\n",
    "print(\"--- 1. Performing 5-Fold Cross-Validation (SVM Stability Test) ---\")\n",
    "\n",
